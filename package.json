{
  "name": "my-architecture-monorepo",
  "private": true,
  "description": "基于 pnpm + TurboRepo 架构的高性能、高度可定制企业级 Monorepo 脚手架系统基座。",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,js,json}\"",
    "prepare": "husky install",
    "copy-templates": "tsx scripts/copy-templates.ts",
    "release": "tsx scripts/release.ts"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "fs-extra": "^11.2.0",
    "husky": "^9.0.11",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^1.12.0",
    "typescript": "^5.3.0"
  }
}