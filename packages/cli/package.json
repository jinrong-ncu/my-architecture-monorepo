        "templates"
    ],
    "scripts": {
        "build": "tsc && tsx ../../scripts/copy-templates.ts",
        "dev": "tsc -w"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "commander": "^11.1.0",
        "fs-extra": "^11.2.0",
        "inquirer": "^8.2.6",
        "ora": "^5.4.1",
        "picocolors": "^1.0.0",
        "tslib": "^2.6.2"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/inquirer": "^8.2.10",
        "tsx": "^4.7.0"
    }
}